#include "push_swap.h"

void	cleanup(t_node *nodes, char *msg, int status)
{
	if (nodes)
	{
		free(nodes);
		nodes = NULL;
	}
	if (msg)
		write(2, msg, ft_strlen(msg));
	exit(status);
}
